# ──────────────────────────────────────────────────────────────────────────────
# APIForge — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=apiforge
POSTGRES_PASSWORD=apiforge_dev_secret
POSTGRES_DB=apiforge_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MongoDB (sample Node.js API) ──────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=mongo_root_secret
MONGO_USER=apiforge
MONGO_PASSWORD=apiforge_secret
MONGO_DB=apiforge_samples
MONGO_HOST=localhost
MONGO_PORT=27017

# ── Kafka (KRaft mode) ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8085

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=apiforge
KEYCLOAK_CLIENT_ID=apiforge-backend
KEYCLOAK_CLIENT_SECRET=apiforge-backend-secret

# ── APIForge Backend ──────────────────────────────────────────────────────────
APIFORGE_SERVER_PORT=8081
APIFORGE_JWT_ISSUER_URI=http://localhost:8080/realms/apiforge
# Secret used to sign internal JWTs if not delegating to Keycloak
APIFORGE_JWT_SECRET=change-me-in-production-use-at-least-32-chars

# ── Java Sample API ───────────────────────────────────────────────────────────
JAVA_SAMPLE_API_PORT=8090
JAVA_SAMPLE_DB_USER=sample_java
JAVA_SAMPLE_DB_PASSWORD=sample_java_secret
JAVA_SAMPLE_DB_NAME=sample_java_db

# ── Node.js Sample API ────────────────────────────────────────────────────────
NODE_SAMPLE_API_PORT=3000
NODE_SAMPLE_MONGO_URI=mongodb://apiforge:apiforge_secret@localhost:27017/apiforge_samples

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true to enable virtual threads (Java 21)
SPRING_THREADS_VIRTUAL_ENABLED=true
